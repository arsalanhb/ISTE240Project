<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Kebab Shop</title>
    <style>
        body { font-family: sans-serif; max-width: 700px; margin: 40px auto; padding: 20px; background-color: #383131; color: #fdfdfd; border-radius: 10px; }
        h1 { color: #d35400; text-align: center; }
        table { width: 100%; border-collapse: collapse; margin-top: 15px; }
        th { background-color: #d35400; color: white; padding: 10px; text-align: left; }
        td { padding: 10px; border-bottom: 1px solid #555; }
        tr:hover { background-color: #4a3f3f; }
        a { display: inline-block; margin-top: 20px; background-color: #d35400; color: white; padding: 10px 20px; border-radius: 6px; text-decoration: none; font-weight: bold; }
        a:hover { background-color: #b94600; }
    </style>
</head>
<body>
<table class="ui celled table">
    <thead>
    <tr>
        <th>Dish Name</th>
        <th>Description</th>
        <th>Price</th>
        <th>Category</th>
        <th>Available</th>
    </tr>
    </thead>
    <tbody>
    {{#dishList}}
        <tr>
            <td>{{dishName}}</td>
            <td>{{description}}</td>
            <td>{{price}}</td>
            <td>{{category}}</td>

            <td>{{available}}</td>
        </tr>
    {{/dishList}}
    </tbody>
</table>
<a href="/">← Back to Home</a>
</body>
</html>
