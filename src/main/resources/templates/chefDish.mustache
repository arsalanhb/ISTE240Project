<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Title</title>
</head>
<body>
<table class="ui celled table">
    <thead>
    <tr>
        <th>Chef Id</th>
        <th>First Name</th>
        <th>Last Name</th>
        <th>Speciality</th>
        <th>YOE</th>
        <th>Salary</th>
        <th>Dishes</th>
    </tr>
    </thead>
    <tbody>
    {{#chefList}}
        <tr>
            <td>{{chefId}}</td>
            <td>{{firstName}}</td>
            <td>{{lastName}}</td>
            <td>{{specialty}}</td>
            <td>{{yrsOfExperience}}</td>
            <td>{{salary}}</td>
            <td>{{#dishList}}
                    {{dishName}}
                    {{description}}
                    {{price}}
                    {{category}}
                    {{available}}
            {{/dishList}}</td>
        </tr>
    {{/chefList}}
    </tbody>
</table>
</body>
</html>
